  <script>
    /* ── ANIMATED BACKGROUND ── */
    const canvas = document.getElementById('bg-canvas');
    const ctx = canvas.getContext('2d');

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    // Floating organic blobs
    const blobs = Array.from({ length: 6 }, (_, i) => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: 180 + Math.random() * 200,
      vx: (Math.random() - 0.5) * 0.3,
      vy: (Math.random() - 0.5) * 0.3,
      hue: i < 3 ? 145 + Math.random() * 20 : 200 + Math.random() * 25,
      sat: 40 + Math.random() * 20,
      light: 80 + Math.random() * 12,
      phase: Math.random() * Math.PI * 2
    }));

    // Particles (floating seeds/droplets)
    const particles = Array.from({ length: 28 }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: 1.5 + Math.random() * 2.5,
      vx: (Math.random() - 0.5) * 0.4,
      vy: -0.2 - Math.random() * 0.4,
      alpha: 0.2 + Math.random() * 0.4,
      type: Math.random() > 0.5 ? 'circle' : 'leaf'
    }));

    let t = 0;

    function drawLeaf(x, y, r, alpha) {
      ctx.save();
      ctx.translate(x, y);
      ctx.rotate(t * 0.5);
      ctx.globalAlpha = alpha;
      ctx.fillStyle = '#2d9e6e';
      ctx.beginPath();
      ctx.moveTo(0, -r * 2);
      ctx.bezierCurveTo(r * 1.5, -r, r * 1.5, r, 0, r * 2);
      ctx.bezierCurveTo(-r * 1.5, r, -r * 1.5, -r, 0, -r * 2);
      ctx.fill();
      ctx.restore();
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      t += 0.005;

      // Draw blobs
      blobs.forEach(b => {
        b.x += b.vx;
        b.y += b.vy;
        if (b.x < -b.r) b.x = canvas.width + b.r;
        if (b.x > canvas.width + b.r) b.x = -b.r;
        if (b.y < -b.r) b.y = canvas.height + b.r;
        if (b.y > canvas.height + b.r) b.y = -b.r;

        const pulse = 1 + 0.06 * Math.sin(t + b.phase);
        const grad = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, b.r * pulse);
        grad.addColorStop(0, `hsla(${b.hue},${b.sat}%,${b.light}%,0.18)`);
        grad.addColorStop(1, `hsla(${b.hue},${b.sat}%,${b.light}%,0)`);
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r * pulse, 0, Math.PI * 2);
        ctx.fillStyle = grad;
        ctx.fill();
      });

      // Draw particles
      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        if (p.y < -10) { p.y = canvas.height + 10; p.x = Math.random() * canvas.width; }
        if (p.x < -10) p.x = canvas.width + 10;
        if (p.x > canvas.width + 10) p.x = -10;

        if (p.type === 'leaf') {
          drawLeaf(p.x, p.y, p.r, p.alpha * 0.6);
        } else {
          ctx.save();
          ctx.globalAlpha = p.alpha;
          ctx.fillStyle = '#3a8fc4';
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }
      });

      requestAnimationFrame(animate);
    }

    animate();

    /* ── SCROLL REVEAL ── */
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });

    revealEls.forEach(el => observer.observe(el));
  </script>
