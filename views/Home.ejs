<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FarmFloodAid — Smart Solutions for Flood Recovery</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after {
      margin: 0; padding: 0; box-sizing: border-box;
    }

    :root {
      --green-deep: #0d3d2b;
      --green-mid: #1a6b49;
      --green-light: #2d9e6e;
      --green-pale: #e4f4ed;
      --earth: #7a5230;
      --earth-pale: #f5ede4;
      --sky: #d4eaf7;
      --water: #3a8fc4;
      --water-dark: #1d5f8a;
      --cream: #faf8f2;
      --text-dark: #1a1a18;
      --text-mid: #4a5046;
      --text-light: #8a9185;
      --white: #ffffff;
      --card-radius: 20px;
      --nav-h: 72px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--cream);
      color: var(--text-dark);
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── ANIMATED BACKGROUND CANVAS ── */
    #bg-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* ── NAVBAR ── */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      height: var(--nav-h);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5vw;
      background: rgba(250,248,242,0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(45,158,110,0.12);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .nav-logo-icon {
      width: 38px;
      height: 38px;
      background: var(--green-mid);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-logo-icon svg {
      width: 22px; height: 22px; fill: white;
    }

    .nav-logo-text {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      font-size: 20px;
      color: var(--green-deep);
      letter-spacing: -0.3px;
    }

    .nav-center {
      position: relative;
    }

    .dropdown { position: relative; }

    .dropbtn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 9px 18px;
      background: transparent;
      border: 1.5px solid rgba(45,158,110,0.3);
      border-radius: 100px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: var(--green-mid);
      cursor: pointer;
      transition: all 0.25s ease;
    }

    .dropbtn:hover {
      background: var(--green-pale);
      border-color: var(--green-light);
    }

    .dropbtn svg { width: 14px; height: 14px; stroke: currentColor; fill: none; transition: transform 0.25s; }
    .dropdown:hover .dropbtn svg { transform: rotate(180deg); }

    .dropdown-content {
      display: none;
      position: absolute;
      top: calc(100% + 10px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--white);
      border: 1px solid rgba(45,158,110,0.15);
      border-radius: 16px;
      min-width: 220px;
      box-shadow: 0 20px 60px rgba(13,61,43,0.12);
      padding: 8px;
      animation: dropIn 0.2s ease;
    }

    @keyframes dropIn {
      from { opacity: 0; transform: translateX(-50%) translateY(-8px); }
      to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }

    .dropdown:hover .dropdown-content { display: block; }

    .dropdown-content a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 14px;
      font-size: 14px;
      color: var(--text-mid);
      text-decoration: none;
      border-radius: 10px;
      transition: background 0.2s, color 0.2s;
    }

    .dropdown-content a:hover {
      background: var(--green-pale);
      color: var(--green-deep);
    }

    .dropdown-content a span.dd-icon {
      width: 28px; height: 28px;
      background: var(--green-pale);
      border-radius: 7px;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px;
    }

    .nav-right { display: flex; align-items: center; gap: 10px; }

    .btn-ghost {
      padding: 9px 20px;
      background: transparent;
      border: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: var(--text-mid);
      cursor: pointer;
      border-radius: 100px;
      transition: background 0.2s, color 0.2s;
      text-decoration: none;
    }

    .btn-ghost:hover { background: var(--green-pale); color: var(--green-deep); }

    .btn-solid {
      padding: 9px 22px;
      background: var(--green-deep);
      border: none;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: white;
      cursor: pointer;
      border-radius: 100px;
      transition: background 0.2s, transform 0.15s;
      text-decoration: none;
    }

    .btn-solid:hover { background: var(--green-mid); transform: translateY(-1px); }

    /* ── HERO ── */
    .hero {
      position: relative;
      z-index: 1;
      min-height: calc(100vh - var(--nav-h));
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero-inner {
      
      
      padding: 80px 6vw;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
      width: 100%;
    }

    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 6px 14px;
      background: rgba(45,158,110,0.12);
      border: 1px solid rgba(45,158,110,0.25);
      border-radius: 100px;
      font-size: 12px;
      font-weight: 500;
      color: var(--green-mid);
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .hero-tag span.dot {
      width: 7px; height: 7px;
      background: var(--green-light);
      border-radius: 50%;
      animation: pulse-dot 2s infinite;
    }

    @keyframes pulse-dot {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.7); }
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 700;
      line-height: 1.15;
      color: var(--green-deep);
      letter-spacing: -1px;
      margin-bottom: 22px;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--green-light);
    }

    .hero-sub {
      font-size: 17px;
      color: var(--text-mid);
      line-height: 1.7;
      font-weight: 300;
      margin-bottom: 40px;
      max-width: 440px;
    }

    .hero-actions { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }

    .btn-hero-primary {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 14px 28px;
      background: var(--green-deep);
      color: white;
      border-radius: 100px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
      box-shadow: 0 6px 24px rgba(13,61,43,0.22);
    }

    .btn-hero-primary:hover {
      background: var(--green-mid);
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(13,61,43,0.28);
    }

    .btn-hero-primary svg { width: 16px; height: 16px; stroke: white; fill: none; }

    .btn-hero-ghost {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 24px;
      border: 1.5px solid rgba(13,61,43,0.2);
      color: var(--text-mid);
      border-radius: 100px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.25s;
    }

    .btn-hero-ghost:hover { border-color: var(--green-mid); color: var(--green-deep); background: var(--green-pale); }

    /* Hero stats */
    .hero-stats {
      display: flex;
      gap: 28px;
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1px solid rgba(45,158,110,0.15);
    }

    .stat { display: flex; flex-direction: column; }
    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--green-deep);
      line-height: 1.1;
    }
    .stat-label { font-size: 12px; color: var(--text-light); font-weight: 400; margin-top: 2px; }

    /* Hero illustration panel */
    .hero-visual {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .hero-card-float {
      position: relative;
      width: 100%;
      max-width: 440px;
    }

    .hero-main-img {
      width: 100%;
      border-radius: 28px;
      overflow: hidden;
      background: linear-gradient(135deg, #c8e6d4 0%, #a0d4b8 50%, #7abfa0 100%);
      aspect-ratio: 4/3;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      position: relative;
    }

    /* Floating badge cards */
    .badge-float {
  position: absolute;
  z-index: 10; /* 👈 Add this line to pull the badges to the front */
  background: white;
  border-radius: 16px;
  padding: 12px 16px;
  box-shadow: 0 12px 40px rgba(13,61,43,0.15);
  display: flex;
  align-items: center;
  gap: 10px;
  animation: float-badge 4s ease-in-out infinite;
}

    .badge-float.top-left {
      top: -16px; left: -20px;
      animation-delay: 0s;
    }

    .badge-float.bottom-right {
      bottom: 20px; right: -24px;
      animation-delay: 1.5s;
    }

    @keyframes float-badge {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .badge-icon {
      width: 36px; height: 36px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }

    .badge-text { display: flex; flex-direction: column; }
    .badge-text strong { font-size: 13px; font-weight: 600; color: var(--text-dark); }
    .badge-text span { font-size: 11px; color: var(--text-light); }

    /* Hero illustration SVG art */
    .hero-illustration {
      width: 100%;
      height: 100%;
      position: absolute;
      inset: 0;
    }

    /* ── SECTION LABEL ── */
    .section-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--green-light);
      margin-bottom: 12px;
    }

    /* ── CARDS SECTION ── */
    .cards-section {
      position: relative;
      z-index: 1;
      padding: 80px 6vw 100px;
      
      
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 48px;
    }

    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      font-weight: 700;
      color: var(--green-deep);
      letter-spacing: -0.5px;
      line-height: 1.2;
    }

    .section-header p {
      font-size: 14px;
      color: var(--text-light);
      
      text-align: right;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .resource-card {
      background: white;
      border-radius: var(--card-radius);
      overflow: hidden;
      border: 1px solid rgba(45,158,110,0.1);
      transition: transform 0.35s cubic-bezier(.22,.68,0,1.2), box-shadow 0.35s ease;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
    }

    .resource-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 28px 72px rgba(13,61,43,0.14);
    }

    .card-visual {
      position: relative;
      height: 200px;
      overflow: hidden;
    }

    .card-visual img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .resource-card:hover .card-visual img { transform: scale(1.06); }

    .card-visual-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(13,61,43,0.45) 0%, transparent 60%);
    }

    .card-chip {
      position: absolute;
      top: 14px; left: 14px;
      padding: 5px 12px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      background: rgba(255,255,255,0.85);
    }

    .chip-ai { color: var(--water-dark); }
    .chip-community { color: #7a3e6a; }
    .chip-ngo { color: var(--earth); }

    .card-content { padding: 24px; flex: 1; display: flex; flex-direction: column; }

    .card-content h3 {
      font-family: 'Playfair Display', serif;
      font-size: 19px;
      font-weight: 700;
      color: var(--green-deep);
      margin-bottom: 10px;
      line-height: 1.3;
    }

    .card-content p {
      font-size: 13.5px;
      color: var(--text-mid);
      line-height: 1.65;
      font-weight: 300;
      flex: 1;
    }

    .card-cta {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin-top: 22px;
      padding: 11px 20px;
      background: var(--green-deep);
      color: white;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 500;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.2s, gap 0.2s;
      align-self: flex-start;
    }

    .card-cta:hover { background: var(--green-mid); gap: 11px; }
    .card-cta svg { width: 14px; height: 14px; stroke: white; fill: none; }

    /* ── BANNER STRIP ── */
    .banner-strip {
      position: relative;
      z-index: 1;
      margin: 0 6vw 80px;
      border-radius: 24px;
      background: var(--green-deep);
      padding: 56px 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      overflow: hidden;
    }

    .banner-strip::before {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
      top: -180px; right: 80px;
    }

    .banner-strip::after {
      content: '';
      position: absolute;
      width: 240px; height: 240px;
      border-radius: 50%;
      background: rgba(255,255,255,0.03);
      bottom: -100px; right: 300px;
    }

    .banner-text h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: white;
      line-height: 1.25;
      margin-bottom: 10px;
    }

    .banner-text p {
      font-size: 15px;
      color: rgba(255,255,255,0.65);
      font-weight: 300;
      max-width: 440px;
    }

    .btn-banner {
      flex-shrink: 0;
      padding: 14px 28px;
      background: white;
      color: var(--green-deep);
      border-radius: 100px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.25s;
      white-space: nowrap;
    }

    .btn-banner:hover { background: var(--green-pale); transform: translateY(-2px); }

    /* ── FOOTER ── */
    footer {
      position: relative;
      z-index: 1;
      background: #0d1f17;
      color: rgba(255,255,255,0.6);
      padding: 60px 6vw 40px;
    }

    .footer-inner {
      
      
      display: grid;
      grid-template-columns: 1.4fr repeat(3, 1fr);
      gap: 48px;
    }

    .footer-brand .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 700;
      color: white;
      margin-bottom: 12px;
    }

    .footer-brand p {
      font-size: 13.5px;
      line-height: 1.7;
      font-weight: 300;
    }

    .footer-brand p a { color: rgba(255,255,255,0.75); text-decoration: none; }
    .footer-brand p a:hover { color: white; }

    .footer-col h4 {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 18px;
    }

    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 10px; }
    .footer-col ul li a {
      font-size: 14px;
      color: rgba(255,255,255,0.55);
      text-decoration: none;
      transition: color 0.2s;
      font-weight: 300;
    }
    .footer-col ul li a:hover { color: white; }

    .footer-bottom {
      
      margin: 48px 0 0;
      padding-top: 24px;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      color: rgba(255,255,255,0.3);
    }

    /* ── REVEAL ANIMATIONS ── */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }

    /* ── HERO ENTRY ANIMATIONS ── */
    .hero-text-wrap > * {
      opacity: 0;
      animation: slideUp 0.7s ease forwards;
    }

    .hero-text-wrap > *:nth-child(1) { animation-delay: 0.1s; }
    .hero-text-wrap > *:nth-child(2) { animation-delay: 0.25s; }
    .hero-text-wrap > *:nth-child(3) { animation-delay: 0.4s; }
    .hero-text-wrap > *:nth-child(4) { animation-delay: 0.55s; }
    .hero-text-wrap > *:nth-child(5) { animation-delay: 0.7s; }

    .hero-visual {
      opacity: 0;
      animation: slideLeft 0.8s 0.3s ease forwards;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes slideLeft {
      from { opacity: 0; transform: translateX(30px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .navbar { padding: 0 5vw; }
      .hero-inner { grid-template-columns: 1fr; gap: 40px; padding: 60px 5vw; }
      .hero-visual { order: -1; max-width: 400px;  }
      .cards-grid { grid-template-columns: 1fr; }
      .cards-section { padding: 60px 5vw 80px; }
      .section-header { flex-direction: column; align-items: flex-start; gap: 8px; }
      .section-header p { text-align: left; }
      .banner-strip { flex-direction: column; padding: 40px 32px; margin: 0 5vw 60px; gap: 24px; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; }
      .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- Animated background canvas -->
  <canvas id="bg-canvas"></canvas>

  <!-- ── NAVBAR ── -->
  <nav class="navbar">
    <a href="/home" class="nav-logo">
      <div class="nav-logo-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6 2 3 7 3 12s3 7 9 10c6-3 9-5 9-10S18 2 12 2z" opacity="0.7"/>
          <path d="M12 6v12M8 10c1-1.5 2.5-2 4-2s3 .5 4 2"/>
        </svg>
      </div>
      <span class="nav-logo-text">FarmFloodAid</span>
    </a>

    <div class="nav-center">
      <div class="dropdown">
        <button class="dropbtn">
          All Resources
          <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="dropdown-content">
          <a href="/chatbot">
            <span class="dd-icon">🤖</span>
            ChatBot
          </a>
          <a href="/interaction">
            <span class="dd-icon">🌾</span>
            Community Interaction
          </a>
          <a href="/govtscheme">
            <span class="dd-icon">🤝</span>
            NGO's
          </a>
        </div>
      </div>
    </div>

    <div class="nav-right">
      <a href="/items" class="btn-ghost">Marketplace</a>
      <a href="#" class="btn-solid">Logout</a>
    </div>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text-wrap">
        <div class="hero-tag">
          <span class="dot"></span>
          Active support network
        </div>
        <h1>Empowering Farmers with <em>Smart Solutions</em> for Flood Recovery</h1>
        <p class="hero-sub">
          Bridging farmers with relief networks and communities — ensuring no crop goes to waste, strengthening livelihoods and supply chains.
        </p>
        <div class="hero-actions">
          <a href="#resources" class="btn-hero-primary">
            Get Access Now
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/chatbot" class="btn-hero-ghost">Talk to AI Bot</a>
