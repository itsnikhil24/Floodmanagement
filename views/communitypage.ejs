<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Flood Aid Marketplace — Sell Your Items</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../stylesheets/community.css">
</head>
<body>
  
  <nav class="navbar">
    <a href="/home" class="nav-logo">
      <div class="nav-logo-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6 2 3 7 3 12s3 7 9 10c6-3 9-5 9-10S18 2 12 2z" opacity="0.7"/>
          <path d="M12 6v12M8 10c1-1.5 2.5-2 4-2s3 .5 4 2"/>
        </svg>
      </div>
      <span class="nav-logo-text">FarmFloodAid</span>
    </a>

    <div class="nav-center">
      <div class="dropdown">
        <button class="dropbtn">
          All Resources
          <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="dropdown-content">
          <a href="/chatbot">
            <span class="dd-icon">🤖</span>
            ChatBot
          </a>
          <a href="/interaction">
            <span class="dd-icon">🌾</span>
            Community Interaction
          </a>
          <a href="/govtscheme">
            <span class="dd-icon">🤝</span>
            NGO's
          </a>
        </div>
      </div>
    </div>

    <div class="nav-right">
      <a href="/items" class="btn-ghost">Marketplace</a>
      <a href="/logout" class="btn-solid">Logout</a>
    </div>
  </nav>

  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <header class="header-section">
    <h1>Flood Aid Marketplace</h1>
    <p>A trusted community platform for farmers to buy, sell, and share essential resources during crisis recovery.</p>
  </header>

  <div class="form-container" id="form-section">
    <div class="form-header">
      <h2>List an Item</h2>
      <a href="/items" class="see-posts-btn">
        View Marketplace 
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <form action="/interaction" method="POST" enctype="multipart/form-data">
      
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" placeholder="E.g. Rajesh Kumar" required>
      </div>
      
      <div class="form-group">
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone" placeholder="+91 XXXXX XXXXX" required>
      </div>
      
      <div class="form-group full-width">
        <label for="address">Pickup Address</label>
        <textarea id="address" name="address" placeholder="Enter the full location where the item can be picked up..." required></textarea>
      </div>
      
      <div class="form-group full-width">
        <label for="item">Item to be Sold</label>
        <input type="text" id="item" name="item" placeholder="E.g. Surplus Wheat, Water Pump, Tractor Rental" required>
      </div>
      
      <div class="form-group">
        <label for="quantity">Quantity (kg/units)</label>
        <input type="number" id="quantity" name="quantity" placeholder="E.g. 50" min="1" required>
      </div>
      
      <div class="form-group">
        <label for="price-range">Expected Price (₹)</label>
        <input type="text" id="price-range" name="price-range" placeholder="E.g. ₹1500 - ₹2000" required>
      </div>

      <div class="form-group full-width">
        <label for="picture">Item Photo</label>
        <div class="file-upload-wrapper">
          <input type="file" id="picture" name="picture" accept="image/*" required>
          <div class="file-upload-text">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
            <span>Click to upload or drag & drop an image</span>
          </div>
        </div>
      </div>
      
      <button type="submit" class="submit-btn">Publish Listing</button>
    </form>
  </div>
  <script>
    const pictureInput = document.getElementById('picture');
    const uploadText = document.querySelector('.file-upload-text span');
    const uploadWrapper = document.querySelector('.file-upload-wrapper');

    pictureInput.addEventListener('change', function(e) {
      if (e.target.files.length > 0) {
        // Get the name of the uploaded file
        const fileName = e.target.files[0].name;
        
        // Update the text to show the file name
        uploadText.textContent = 'Selected: ' + fileName;
        
        // Optional: Change the box styling slightly to indicate success
        uploadWrapper.style.borderColor = 'var(--green-mid)';
        uploadWrapper.style.backgroundColor = 'var(--green-pale)';
        uploadText.style.color = 'var(--green-deep)';
        uploadText.style.fontWeight = '600';
      } else {
        // Reset if the user cancels the file selection
        uploadText.textContent = 'Click to upload or drag & drop an image';
        uploadWrapper.style.borderColor = '';
        uploadWrapper.style.backgroundColor = '';
        uploadText.style.fontWeight = '500';
      }
    });
  </script>

</body>
</html>